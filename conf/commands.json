{
    "motd": "Welcome to AetherCLI - Advanced Management Shell\nType '?' or double-tab for help.\n",
    "commands": [
        {
            "name": "show",
            "abbrev": "sh",
            "short_desc": "Exibir informações do sistema",
            "subcommands": [
                {
                    "name": "ip",
                    "short_desc": "Informações de rede IP",
                    "subcommands": [
                        {
                            "name": "interface",
                            "short_desc": "Status das interfaces",
                            "activation": "ip addr show",
                            "syntax": "show ip interface"
                        },
                        {
                            "name": "route",
                            "short_desc": "Tabela de roteamento",
                            "activation": "ip route show",
                            "syntax": "show ip route"
                        }
                    ]
                },
                {
                    "name": "files",
                    "short_desc": "Listar arquivos",
                    "activation": "ls -la",
                    "syntax": "show files [path]",
                    "args": "append"
                },
                {
                    "name": "version",
                    "short_desc": "Versão do sistema",
                    "activation": "uname -a",
                    "syntax": "show version"
                }
            ]
        },
        {
            "name": "configure",
            "abbrev": "conf",
            "short_desc": "Entrar no modo de configuração",
            "subcommands": [
                {
                    "name": "terminal",
                    "short_desc": "Configurar via terminal",
                    "activation": "internal:config_mode",
                    "syntax": "configure terminal"
                }
            ]
        },
        {
            "name": "run",
            "short_desc": "Executar macros",
            "subcommands": [
                {
                    "name": "macro",
                    "short_desc": "Executar arquivo .macro",
                    "activation": "internal:run_macro",
                    "syntax": "run macro <arquivo.macro>",
                    "args": "append"
                }
            ]
        },
        {
            "name": "list",
            "short_desc": "Listagens do engine",
            "subcommands": [
                {
                    "name": "macros",
                    "short_desc": "Listar arquivos .macro disponíveis",
                    "activation": "internal:list_macros",
                    "syntax": "list macros"
                }
            ]
        },
        {
            "name": "ai",
            "short_desc": "Perguntar à IA local (Ollama)",
            "activation": "internal:ai",
            "syntax": "ai <pergunta em linguagem natural>",
            "args": "append"
        },
        {
            "name": "iris",
            "short_desc": "Íris — assistente local",
            "subcommands": [
                {
                    "name": "face",
                    "short_desc": "Abrir o rosto da Íris no browser",
                    "activation": "open \"${IRIS_FACE_URL:-http://localhost:8090}\"",
                    "syntax": "iris face"
                },
                {
                    "name": "status",
                    "short_desc": "Ver se o rosto da Íris responde",
                    "activation": "curl -s -o /dev/null -w 'face: HTTP %{http_code}\\n' --max-time 3 http://localhost:8090/ || echo 'face: fora do ar'",
                    "syntax": "iris status"
                }
            ]
        }
    ]
}
